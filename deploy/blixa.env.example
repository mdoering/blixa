# Blixa backend environment — GBIF dev.
# Copy to /home/col/bin/blixa/blixa.env, fill in the CHANGE_ME secrets, chmod 600, chown col:col.
# Keep the real file OUT of git (the private deploy repo or the VM only) — this .example is the
# committed template with placeholders.
#
# NOTE: production/dev deployments run the DEFAULT profile (no SPRING_PROFILES_ACTIVE=dev). The `dev`
# profile seeds an admin/admin login and is for local demos ONLY. Deployed login is ORCID.

# --- database (native PostgreSQL 17, see db-init.sql) ---
DB_URL=jdbc:postgresql://localhost:5432/blixa
DB_USER=blixa
DB_PASSWORD=CHANGE_ME

# --- ORCID OAuth2 login ---
# Register the app at orcid.org; set the redirect URI to
#   https://blixa.dev.catalogueoflife.org/login/oauth2/code/orcid
ORCID_CLIENT_ID=APP-XXXXXXXXXXXXXXXX
ORCID_CLIENT_SECRET=CHANGE_ME

# --- behind the Apache reverse proxy ---
# Honor X-Forwarded-Proto/Host so Spring builds correct https absolute URLs (incl. the ORCID
# redirect_uri). Apache must send those headers (see the vhost).
SERVER_FORWARD_HEADERS_STRATEGY=framework

# --- artifact storage (writable by the 'col' user; Apache can serve exports for download) ---
COLDP_EXPORT_DIR=/mnt/auto/col/blixa/exports
COLDP_IMPORT_DIR=/mnt/auto/col/blixa/imports
# Reference-PDF storage (COLDP_PDF_DIR -> coldp.pdf.dir). Apache serves this dir at /pdf (see the
# vhost's Alias); PDF uploads (POST .../references/{id}/pdf) write here, and GET /pdf/<file>
# (public, no auth) streams them back.
COLDP_PDF_DIR=/mnt/auto/col/blixa/pdfs
# Public base URL for hosted reference PDFs (COLDP_PDF_BASE_URL -> coldp.pdf.base-url). Defaults to
# the relative "/pdf" (fine when the app serves GET /pdf/{filename} itself on the same origin as the
# API). Set an absolute URL if PDFs are served from a different host/vhost than this app, e.g.:
# COLDP_PDF_BASE_URL=https://blixa.dev.catalogueoflife.org/pdf

# --- CLB API for name matching (COL match + merge dataset lookups) ---
# Defaults to prod api.checklistbank.org; point at dev if preferred.
COLDP_CLB_BASE_URL=https://api.dev.checklistbank.org

# --- server port (Apache proxies to this; not exposed directly) ---
SERVER_PORT=8111

# --- JVM ---
JAVA_OPTS=-Xmx4g
